{
 "name": "lottie-toolkit",
  "displayName": "Lottie Toolkit",
  "description": "Preview .lottie and Lottie JSON animations, and open previews from HTML and Vue source files in Visual Studio Code.",
  "icon": "icon.png",
  "version": "1.2.0",
  "publisher": "tangkeimg",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangkeimg/lottie-toolkit.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "lottie",
    "lottie preview link",
    "lottie source preview",
    "lottie preview",
    "lottie viewer",
    "lottie animation",
    "lottie json",
    "lottie-web",
    "dotlottie",
    "dotlottie preview",
    ".lottie",
    "html lottie",
    "vue lottie"
  ],
  "scripts": {
    "package:vsix": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run package",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:html",
    "onLanguage:vue",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "workspaceContains:**/*.vue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lottie-toolkit.openPreview",
        "title": "Open Lottie Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lottie-toolkit.openPreview",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "lottie-toolkit.preview",
        "displayName": "Lottie Preview",
        "selector": [
          {
            "filenamePattern": "*.lottie"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "lottie-toolkit.jsonPreview",
        "displayName": "Lottie Preview",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ]
  },

  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.72.0",
    "lottie-web": "^5.13.0"
  }
}
